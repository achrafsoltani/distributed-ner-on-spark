# Copy this file to .env and fill in your own values.
# The .env file is gitignored and must never be committed.

# -------------------------------------------------------------------------
# HuggingFace — write access for pushing student models to the Hub
# Generate at: https://huggingface.co/settings/tokens
# -------------------------------------------------------------------------
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------------------
# AWS Bedrock — for the Teacher agent (Claude Sonnet 4.6 + Haiku 4.5)
#
# AWS credentials themselves come from the standard AWS credential chain
# (~/.aws/credentials, env vars, or IAM role) — not from this file.
#
# Verify the exact Bedrock model IDs for your region with:
#   aws bedrock list-foundation-models --by-provider anthropic
# -------------------------------------------------------------------------
BEDROCK_REGION=eu-west-1
BEDROCK_SONNET_MODEL_ID=eu.anthropic.claude-sonnet-4-6
BEDROCK_HAIKU_MODEL_ID=eu.anthropic.claude-haiku-4-5-20251001-v1:0

# -------------------------------------------------------------------------
# HuggingFace cache root (optional — defaults to ~/.cache/huggingface)
# -------------------------------------------------------------------------
HF_HOME=
